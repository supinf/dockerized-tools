{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(npm view *)",
      "Bash(npm show *)",
      "Bash(curl -s *)",
      "Bash(curl -fsSL *)",
      "Bash(gh api *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force *)"
    ]
  }
}
